{
  "manifest_version": 2,
  "name": "awawausb",
  "version": "0.1",

  "default_locale": "en",

  "description": "__MSG_manifest_descr__",

  "browser_specific_settings": {
    "gecko": {
      "id": "awawausb@arcanenibble.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "browser_action": {
    "default_icon": "icons/browser-action.png",
    "default_title": "__MSG_button_open_debug__"
  },

  "content_scripts": [
    {
      "all_frames": true,
      "run_at": "document_start",
      "world": "ISOLATED",
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }, {
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN",
      "matches": ["<all_urls>"],
      "js": ["page.js"]
    }
  ],

  "background": {
    "scripts": ["awawausb.js"],
    "persistent": true
  },

  "permissions": ["nativeMessaging", "notifications"]
}
